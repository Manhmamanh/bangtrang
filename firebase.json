{
  "hosting": {
    "public": "packages/client/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "packages/server",
    "runtime": "nodejs20",
    "codebase": "default"
  }
}
